# Copy this file to .env.local and fill in your Supabase project's values.
# Dashboard -> Project Settings -> API Keys
#   VITE_SUPABASE_URL      = "Project URL"      (https://<ref>.supabase.co)
#   VITE_SUPABASE_ANON_KEY = "Publishable key"  (sb_publishable_...)
#
# The key is public by design — row level security in schema.sql is what
# protects the data. Vite inlines both values into the built JS.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY
